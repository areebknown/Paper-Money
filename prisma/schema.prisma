generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String?
  email     String?  @unique
  isAdmin   Boolean  @default(false)
  isSuspended Boolean @default(false)
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  
  // Custom Identity & Auth
  publicId    String?  @unique // PMUID (8-digit random)
  isMainAccount Boolean @default(false)
  realName    String?
  realNameUpdatedAt DateTime?
  about       String?  // Bio / about text shown on public profile
  profileImage String?
  phoneNumber  String?  @unique
  telegramId   String?  @unique // Telegram chat.id — one human = one Main Account
  lastSeenAt   DateTime? // Updated on every authenticated request

  resetToken       String?
  resetTokenExpiry DateTime?
  
  // Bid Wars: Rank & Progression
  rankPoints Int      @default(0)
  loanTokens Int      @default(1)
  greenMoney Decimal  @default(0) @db.Decimal(10, 2)
  rankTier   String   @default("BRONZE") // BRONZE, SILVER, GOLD, DIAMOND
  lastWeeklyClaim DateTime? // Tracks when the user last received weekly rank perks
  
  interestTag String?    // Bidder, Investor, Lender, Collector, Digger, Pawnbroker
  showInterest Boolean   @default(true)
  showNetworth Boolean   @default(false)
  showRank     Boolean   @default(true)
  showLeaderboard Boolean @default(true)
  showPawnBadge   Boolean @default(false)

  
  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  portfolios           Portfolio[]
  ownedArtifacts       Artifact[]    @relation("ArtifactOwner")
  auctionBids          AuctionBid[]
  pawnShop             PawnShop?
  contracts            Contract[]
  wonAuctions          Auction[]     @relation("AuctionWinner")
  exitedAuctions       Auction[]     @relation("AuctionExited")
  notificationSubs     AuctionNotificationSubscription[]
  coupons              Coupon[]      @relation("UserCoupons")
  
  // WebAuthn Biometrics
  authenticators       Authenticator[]

  // Finance Account → Main Account link
  parentAccountId String?
  parentAccount   User?   @relation("FinanceToMain", fields: [parentAccountId], references: [id])
  financeAccounts User[]  @relation("FinanceToMain")

  reservedUsernames ReservedUsername[] @relation("UserReservedUsernames")

  queries         PlayerQuery[]

  // Friends
  sentFriendRequests     Friendship[] @relation("FriendshipSender")
  receivedFriendRequests Friendship[] @relation("FriendshipReceiver")

  ownedEstates    Estate[]
  ownedVehicles   Vehicle[]
}

model Estate {
  id          String   @id @default(cuid())
  name        String
  value       Decimal  @db.Decimal(12, 2)
  imageUrl    String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Vehicle {
  id          String   @id @default(cuid())
  name        String
  value       Decimal  @db.Decimal(12, 2)
  imageUrl    String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// Friendship model — mutual friendship after accepted
model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model ReservedUsername {
  id        String   @id @default(cuid())
  username  String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation("UserReservedUsernames", fields: [userId], references: [id], onDelete: Cascade)
}

enum AuctionStatus {
  SCHEDULED
  WAITING_ROOM
  LIVE
  COMPLETED
  ENDED
  VOID
}

model Coupon {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserCoupons", fields: [userId], references: [id], onDelete: Cascade)
  
  type        String   // "CASHBACK", "DISCOUNT", "BID_PULL", "PREMIUM", "SHUTTER_PASS"
  description String   // e.g., "Weekly Cashback Coupon", "Special Shutters Access", "Better Discount Coupon"
  multiplier  Decimal? @db.Decimal(5, 2) // e.g., 1.50, 0.20
  
  isUsed      Boolean  @default(false)
  expiresAt   DateTime? // Weekly coupons expire
  createdAt   DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("COMPLETED") // COMPLETED, FAILED
  category    String   @default("TRANSFER") // TRANSFER, MARKET_BUY, MARKET_SELL
  description String?
  createdAt   DateTime @default(now())

  senderId    String
  sender      User     @relation("SentTransactions", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId  String
  receiver    User     @relation("ReceivedTransactions", fields: [receiverId], references: [id], onDelete: Cascade)

  assetId     String? // For market transactions
  asset       Asset?   @relation(fields: [assetId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([assetId])
}

model Asset {
  id           String             @id
  name         String
  description  String?
  unit         String
  currentPrice Decimal  @db.Decimal(10, 2)
  change24h    Decimal  @default(0) @db.Decimal(10, 2)
  history      AssetPriceHistory[]
  portfolios   Portfolio[]
  transactions Transaction[]
}

model AssetPriceHistory {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price     Decimal  @db.Decimal(10, 2)
  timestamp DateTime @default(now())

  @@index([assetId])
  @@index([timestamp])
}

model MarketEvent {
  id          String   @id @default(cuid())
  assetId     String   @default("ALL") // Specific asset ID or "ALL"
  type        String   // BOOM or CRASH
  magnitude   Decimal  @db.Decimal(5, 4) // e.g. 0.20 for 20%
  status      String   @default("PENDING") // PENDING, EXECUTED, CANCELLED
  createdAt   DateTime @default(now())
  executedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  units     Decimal  @default(0) @db.Decimal(15, 8)
  totalCost Decimal  @default(0) @db.Decimal(10, 2) // Tracks cost basis for P/L

  @@unique([userId, assetId])
}

// ============================================
// BID WARS MODELS
// ============================================

model Artifact {
  id          String   @id @default(cuid())
  productId   Int      @unique @default(autoincrement()) // Product ID (PID), starting from 10001
  name        String
  description String?
  imageUrl    String?
  
  // Valuation
  basePoints     Decimal @db.Decimal(10, 2) // BP
  materialComposition Json? // {"gold": 2.5, "silver": 10} in grams
  tier           String  @default("E") // Artifact Tier (E to SSS+)
  
  // Dimensions for visual scaling
  width  Decimal? @db.Decimal(8, 2) // relative units
  height Decimal? @db.Decimal(8, 2) // relative units
  depth  Decimal? @db.Decimal(8, 2) // relative units
  
  // Ownership
  ownerId    String?
  owner      User?    @relation("ArtifactOwner", fields: [ownerId], references: [id])
  
  // Tracking
  viewCount  Int      @default(0)
  lastViewed DateTime?
  createdAt  DateTime @default(now())
  
  // Pawn Shop
  pawnShopId String?
  pawnShop   PawnShop? @relation(fields: [pawnShopId], references: [id])
  
  // Relations
  auctions   AuctionArtifact[]
  
  @@index([ownerId])
  @@index([pawnShopId])
}

model Auction {
  id          String   @id @default(cuid())
  name        String
  
  // Timing
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  
  // Rank & Pricing
  rankTier     String  // GOLD, SILVER, BRONZE
  startingPrice Decimal @db.Decimal(10, 2)
  currentPrice  Decimal @db.Decimal(10, 2)
  
  // State
  status       String  @default("SCHEDULED")
  
  // Winner
  winnerId     String?
  winner       User?   @relation("AuctionWinner", fields: [winnerId], references: [id])

  // Pay & Claim — deduction is deferred to claim time
  isClaimed       Boolean   @default(false)
  claimExpiresAt  DateTime? // 24h window; null until auction COMPLETED

  // Last bid timestamp — used server-side to reject premature end calls
  lastBidAt    DateTime?

  createdAt    DateTime @default(now())
  
  // Relations
  artifacts    AuctionArtifact[]
  bids         AuctionBid[]
  exitedUsers  User[]        @relation("AuctionExited")
  notificationSubs AuctionNotificationSubscription[]
  
  @@index([status])
  @@index([scheduledAt])
}

// Junction table for Auction <-> Artifact (many-to-many)
model AuctionArtifact {
  id         String   @id @default(cuid())
  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  artifactId String
  artifact   Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  
  @@unique([auctionId, artifactId])
  @@index([auctionId])
  @@index([artifactId])
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  
  amount    Decimal  @db.Decimal(10, 2)
  timestamp DateTime @default(now())
  
  @@index([auctionId])
  @@index([bidderId])
  @@index([timestamp])
}

model PawnShop {
  id       String   @id @default(cuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isActive Boolean  @default(false)
  activatedAt DateTime?
  
  // Admin-controlled
  activationCost Decimal @default(0) @db.Decimal(10, 2)
  pspValue       Decimal @default(0) @db.Decimal(10, 2) // PSP assigned to artifacts
  
  artifacts Artifact[]
  
  createdAt DateTime @default(now())
}

model Contract {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation(fields: [fromUserId], references: [id], onDelete: Cascade)
  
  toUserId    String?
  description String
  terms       Json?    // Flexible contract data
  
  // Verification
  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?
  verifiedBy  String?  // Admin username
  
  createdAt   DateTime @default(now())
  
  @@index([fromUserId])
  @@index([isVerified])
}

// Stores which users opted into push notifications for a specific auction.
// Created when the user taps the bell icon on an auction card.
model AuctionNotificationSubscription {
  id        String  @id @default(cuid())
  userId    String
  auctionId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([auctionId])
}

// ============================================
// AUTHENTICATION MODELS (WebAuthn / Passkeys)
// ============================================

model Authenticator {
  credentialID         String  @id
  userId               String
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String? // Comma-separated: "internal,usb,nfc,ble"

  @@index([userId])
}

// ============================================
// PLAYER QUERIES
// ============================================

model PlayerQuery {
  id        String   @id @default(cuid())
  userId    String?  // Optional, in case the user gets deleted
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  contact   String   // Phone or Telegram ID
  text      String   @db.Text
  createdAt DateTime @default(now())
  
  @@index([createdAt])
}
